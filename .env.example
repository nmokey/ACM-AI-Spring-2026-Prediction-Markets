# Copy this file to .env and fill in your keys. Never commit .env to git.

# Kalshi API — https://trading-api.kalshi.com/docs
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_API_SECRET=your_kalshi_api_secret_here
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2

# GNews API — https://gnews.io (request free academic access with UCLA email)
GNEWS_API_KEY=your_gnews_api_key_here

# Binance — public endpoints require no auth, but add keys here if needed
# BINANCE_API_KEY=
# BINANCE_SECRET=
